---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PatchRow from '../components/PatchRow.astro';
import { wasteRatio } from '../lib/format.ts';

const games = await getCollection('games');
const gameMap = new Map(games.map(g => [g.data.slug, g.data]));
const patches = await getCollection('patches');
const ranked = patches
  .map(p => {
    const g = gameMap.get(p.data.game_slug);
    return {
      ...p.data,
      game_title: g?.title ?? p.data.game_slug
    };
  })
  .sort((a, b) =>
    wasteRatio(b.bytes_downloaded, b.bytes_actual_change) -
    wasteRatio(a.bytes_downloaded, a.bytes_actual_change)
  );
---
<Base title="patch|waste leaderboard" description="Public ranking of game patches by bytes redownloaded per byte of actual change.">
  <section class="mb-10">
    <h1 class="text-4xl font-mono tracking-tight">
      How much did your patch <span class="text-rust">waste</span>?
    </h1>
    <p class="mt-3 text-mute max-w-2xl">
      Every entry shows what players actually downloaded against the bytes of new or changed content.
      A waste ratio of 50x means the studio shipped 50 GB of patch data for every 1 GB of real change.
      Curated from public reports and depot manifests. Methodology is open;
      <a href="/methodology/" class="underline text-ink hover:text-rust">read it here</a>.
    </p>
    <div class="mt-4 text-xs text-mute font-mono uppercase tracking-wider">
      {ranked.length} patches indexed · seed corpus
    </div>
  </section>

  <section>
    <div class="grid grid-cols-12 gap-4 text-xs text-mute font-mono uppercase tracking-wider px-2 -mx-2 pb-2 border-b border-line">
      <div class="col-span-1">#</div>
      <div class="col-span-5">Patch</div>
      <div class="col-span-3 text-right">Downloaded</div>
      <div class="col-span-3 text-right">Ratio</div>
    </div>
    {ranked.map((p, i) => (
      <PatchRow
        rank={i + 1}
        game_title={p.game_title}
        game_slug={p.game_slug}
        version={p.version}
        released={p.released}
        bytes_downloaded={p.bytes_downloaded}
        bytes_actual_change={p.bytes_actual_change}
        cause_tag={p.cause_tag}
        confidence={p.confidence}
      />
    ))}
  </section>

  <section class="mt-12 p-6 border border-line bg-line/20">
    <h2 class="font-mono text-lg">Want your studio off this list?</h2>
    <p class="text-sm text-mute mt-2 max-w-2xl">
      patchwaste runs as a CI gate against your Unreal or Unity build output and tells you
      the redownload cost before the patch ships to players.
    </p>
    <a href="/signup/" class="inline-block mt-4 bg-ink text-bone font-mono px-4 py-2 rounded hover:bg-rust">
      Get free access
    </a>
  </section>
</Base>
